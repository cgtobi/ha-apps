#!/usr/bin/with-contenv sh
set -eu

timestamp() {
  date +"%Y-%m-%dT%H:%M:%S%z"
}

log() {
  echo "$(timestamp) [web] $*"
}

log "Starting web server on :8080"

# Config is reconciled and the /var/www/config/app symlink is created by init
# before this service starts; nothing recreates them afterward. Do NOT reconcile
# or re-link here: blocking on the reconcile lock would hold the web server (and
# /healthz) behind the backgrounded data reconcile's long import, and re-linking
# races the daemon service (both ran `ln -s` → `ln: .../app/app: File exists`).

exec frankenphp run --config /etc/frankenphp/Caddyfile

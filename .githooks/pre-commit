#!/usr/bin/env sh
set -eu

CONFIG_FILE="statistics_for_strava/config.yaml"

if ! git rev-parse --git-dir >/dev/null 2>&1; then
  exit 0
fi

if [ ! -f "$CONFIG_FILE" ]; then
  exit 0
fi

staged_in_addon="$(git diff --cached --name-only --diff-filter=ACMR -- 'statistics_for_strava/**' 'statistics_for_strava/*' ':!statistics_for_strava/config.yaml' || true)"
if [ -z "$staged_in_addon" ]; then
  exit 0
fi

extract_version() {
  sed -n 's/^version:[[:space:]]*"\([0-9][0-9]*\.[0-9][0-9]*\.[0-9][0-9]*\)".*/\1/p' | head -n1
}

staged_version="$(git show ":${CONFIG_FILE}" 2>/dev/null | extract_version || true)"
if [ -z "$staged_version" ]; then
  echo "pre-commit: could not read staged version from ${CONFIG_FILE}" >&2
  exit 1
fi

head_version="$(git show "HEAD:${CONFIG_FILE}" 2>/dev/null | extract_version || true)"
if [ -n "$head_version" ] && [ "$staged_version" != "$head_version" ]; then
  echo "pre-commit: ${CONFIG_FILE} version already changed (${staged_version}), skipping auto-bump"
  exit 0
fi

IFS=. read -r major minor patch <<EOF
$staged_version
EOF

if [ -z "${major:-}" ] || [ -z "${minor:-}" ] || [ -z "${patch:-}" ]; then
  echo "pre-commit: invalid version '${staged_version}' in ${CONFIG_FILE}" >&2
  exit 1
fi

next_patch=$((patch + 1))
next_version="${major}.${minor}.${next_patch}"

tmp_file="$(mktemp)"
awk -v next_version="$next_version" '
  BEGIN { updated = 0 }
  /^version:[[:space:]]*"/ && updated == 0 {
    print "version: \"" next_version "\""
    updated = 1
    next
  }
  { print }
  END {
    if (!updated) {
      print "pre-commit: version line not found in config.yaml" > "/dev/stderr"
      exit 1
    }
  }
' "$CONFIG_FILE" > "$tmp_file"
mv "$tmp_file" "$CONFIG_FILE"

git add "$CONFIG_FILE"
echo "pre-commit: bumped ${CONFIG_FILE} version ${staged_version} -> ${next_version}"

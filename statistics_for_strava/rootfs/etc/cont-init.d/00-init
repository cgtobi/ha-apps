#!/usr/bin/with-contenv sh
set -eu

timestamp() {
  date +"%Y-%m-%dT%H:%M:%S%z"
}

log() {
  echo "$(timestamp) [init] $*"
}

warn() {
  echo "$(timestamp) [init] WARN: $*"
}

fatal() {
  echo "$(timestamp) [init] FATAL: $*"
}

log "Preparing persistent storage"

OPTIONS_FILE="/data/options.json"
HA_ADDON_CONFIG_DIR="/addon_configs/local_statistics_for_strava"
PERSIST_CONFIG_DIR="/data/config/app"
TARGET_CONFIG_DIR="/var/www/config/app"
TARGET_STORAGE_DIR="/var/www/storage"
# File-import watch dir. addon_config:rw mounts the add-on's config dir at /config
# inside the container (host: /addon_configs/local_statistics_for_strava), so files
# dropped here over SMB/CIFS are picked up by the upstream file-import pipeline.
WATCH_SOURCE_DIR="/config/watch"
TARGET_WATCH_DIR="/var/www/watch"
STARTUP_MARKER_FILE="/data/runtime/health.startup"
S6_ENV_DIR_1="/var/run/s6/container_environment"
S6_ENV_DIR_2="/run/s6/container_environment"

mkdir -p /data/build/html /data/build/api
mkdir -p /data/storage/database /data/storage/files/logs /data/storage/gear-maintenance
mkdir -p /data/runtime
mkdir -p "$PERSIST_CONFIG_DIR"

# Startup marker used by /healthz grace handling.
date +%s > "$STARTUP_MARKER_FILE"

# Ensure app config path points to persistent data.
if [ -L "$TARGET_CONFIG_DIR" ]; then
  rm -f "$TARGET_CONFIG_DIR"
elif [ -d "$TARGET_CONFIG_DIR" ]; then
  rm -rf "$TARGET_CONFIG_DIR"
elif [ -f "$TARGET_CONFIG_DIR" ]; then
  rm -f "$TARGET_CONFIG_DIR"
fi
mkdir -p /var/www/config
ln -s "$PERSIST_CONFIG_DIR" "$TARGET_CONFIG_DIR"

# Ensure app-relative storage path resolves to persistent /data/storage.
if [ -L "$TARGET_STORAGE_DIR" ]; then
  rm -f "$TARGET_STORAGE_DIR"
elif [ -d "$TARGET_STORAGE_DIR" ]; then
  rm -rf "$TARGET_STORAGE_DIR"
elif [ -f "$TARGET_STORAGE_DIR" ]; then
  rm -f "$TARGET_STORAGE_DIR"
fi
ln -s /data/storage "$TARGET_STORAGE_DIR"

# One-time DB rename to match the v5 default filename. Existing v4 installs have
# strava.db; v5 uses dreeve.db (both work, but we standardise on dreeve.db). The
# DB is closed here (services start later), so renaming the file plus its WAL/SHM
# sidecars is safe. Idempotent: only when strava.db exists and dreeve.db does not
# (never clobber an existing dreeve.db).
DB_DIR="/data/storage/database"
if [ -f "$DB_DIR/strava.db" ] && [ ! -f "$DB_DIR/dreeve.db" ]; then
  for suf in "" "-wal" "-shm"; do
    if [ -f "$DB_DIR/strava.db${suf}" ]; then
      mv "$DB_DIR/strava.db${suf}" "$DB_DIR/dreeve.db${suf}"
    fi
  done
  log "Renamed existing strava.db to dreeve.db"
fi

# Backward-compatible import for existing user file locations.
import_legacy_config_once() {
  LEGACY_CONFIG_IMPORTED="false"
  if [ ! -f "$PERSIST_CONFIG_DIR/config.yaml" ]; then
    if [ -f "$HA_ADDON_CONFIG_DIR/config/app/config.yaml" ]; then
      cp "$HA_ADDON_CONFIG_DIR/config/app/config.yaml" "$PERSIST_CONFIG_DIR/config.yaml"
      LEGACY_CONFIG_IMPORTED="true"
    elif [ -f "$HA_ADDON_CONFIG_DIR/config.yaml" ]; then
      cp "$HA_ADDON_CONFIG_DIR/config.yaml" "$PERSIST_CONFIG_DIR/config.yaml"
      LEGACY_CONFIG_IMPORTED="true"
    fi
  fi
}

require_non_empty() {
  key="$1"
  value="$2"
  if [ -z "$value" ]; then
    fatal "Required option '${key}' is empty"
    exit 1
  fi
}

# Write runtime env expected by Symfony app.
if [ ! -f "$OPTIONS_FILE" ]; then
  fatal "Missing required ${OPTIONS_FILE}"
  exit 1
fi

read_opt() {
  key="$1"
  jq -r --arg k "$key" '.[$k] // ""' "$OPTIONS_FILE"
}

IMPORT_MODE="$(read_opt import_mode)"
: "${IMPORT_MODE:=stravaApi}"
STRAVA_CLIENT_ID="$(read_opt strava_client_id)"
STRAVA_CLIENT_SECRET="$(read_opt strava_client_secret)"
STRAVA_REFRESH_TOKEN="$(read_opt strava_refresh_token)"
TZ_VALUE="$(read_opt tz)"
APP_URL="$(read_opt app_url)"
ADMIN_USERNAME="$(read_opt admin_username)"
: "${ADMIN_USERNAME:=admin}"
ADMIN_PASSWORD="$(read_opt admin_password)"
EXPOSE_SHARE="$(read_opt expose_share)"
CADDY_LOG_LEVEL="$(read_opt caddy_log_level)"

# Strava credentials are only required in Strava-API import mode. In "files" mode
# the app imports activity files from the watch dir and needs no Strava tokens.
if [ "$IMPORT_MODE" = "stravaApi" ]; then
  require_non_empty "strava_client_id" "$STRAVA_CLIENT_ID"
  require_non_empty "strava_client_secret" "$STRAVA_CLIENT_SECRET"
  require_non_empty "strava_refresh_token" "$STRAVA_REFRESH_TOKEN"
fi
require_non_empty "tz" "$TZ_VALUE"
require_non_empty "admin_password" "$ADMIN_PASSWORD"

# The app's AppUrl value object rejects an empty/invalid URL, so APP_URL must be a
# valid non-empty URL. For Home Assistant ingress the value is only a placeholder:
# the real ingress prefix comes from X-Forwarded-Prefix, not app_url. So default to
# a valid placeholder instead of failing, letting the add-on boot out of the box.
# Direct-access / Strava-webhook users should set a real, publicly reachable URL.
if [ -z "$APP_URL" ]; then
  APP_URL="http://localhost:8080"
  warn "app_url not set; defaulting to ${APP_URL} (set a real URL for direct access or Strava webhooks)"
fi
# Persist the resolved APP_URL so start.sh hands the same value to the services
# (00-init runs as a child of start.sh, so its exports do not propagate up).
printf '%s' "$APP_URL" > /data/runtime/app_url

# APP_SECRET signs the admin session cookie. It must be stable across restarts
# (a changed secret invalidates every session) but need not be user-visible, so
# generate it once and persist under /data.
APP_SECRET_FILE="/data/runtime/app_secret"
if [ ! -s "$APP_SECRET_FILE" ]; then
  head -c 32 /dev/urandom | od -An -tx1 | tr -d ' \n' > "$APP_SECRET_FILE"
  log "Generated new APP_SECRET"
fi
APP_SECRET="$(cat "$APP_SECRET_FILE")"
chmod 600 "$APP_SECRET_FILE" 2>/dev/null || true

# Hash the plaintext admin_password into the hash the app verifies against. The
# app itself produces it so the algorithm always matches.
ADMIN_PASSWORD_HASH="$(cd /var/www \
  && COLUMNS=400 php bin/console security:hash-password "$ADMIN_PASSWORD" --no-interaction 2>/dev/null \
  | grep -Eo '\$(argon2id|argon2i|2y)\$[^[:space:]]+' | tail -n1)"
if [ -z "$ADMIN_PASSWORD_HASH" ]; then
  fatal "Could not hash admin_password via security:hash-password"
  exit 1
fi
# start.sh runs this script as a child, so exports do not propagate up. Persist
# the hash to a runtime file (like app_secret) so start.sh can read it back and
# export it to the daemon / web services (the v5 image has no s6 env dirs).
printf '%s' "$ADMIN_PASSWORD_HASH" > /data/runtime/admin_password_hash
chmod 600 /data/runtime/admin_password_hash 2>/dev/null || true

# Expose the file-import watch dir via the mapped add-on config dir so activity
# files can be provided over SMB/CIFS. Gated by expose_share: when off, the watch
# dir stays internal/unused. Same link idiom as the storage symlink above.
if [ "$EXPOSE_SHARE" = "true" ]; then
  if [ -L "$TARGET_WATCH_DIR" ]; then
    rm -f "$TARGET_WATCH_DIR"
  elif [ -d "$TARGET_WATCH_DIR" ]; then
    rm -rf "$TARGET_WATCH_DIR"
  elif [ -f "$TARGET_WATCH_DIR" ]; then
    rm -f "$TARGET_WATCH_DIR"
  fi
  if mkdir -p "$WATCH_SOURCE_DIR" 2>/dev/null; then
    ln -s "$WATCH_SOURCE_DIR" "$TARGET_WATCH_DIR"
    log "File-import watch dir exposed at ${WATCH_SOURCE_DIR} (host: /addon_configs/local_statistics_for_strava/watch)"
  else
    warn "expose_share=true but ${WATCH_SOURCE_DIR} is not writable; is 'addon_config:rw' mapped?"
  fi
fi

# v5 reads config.yaml only once, on first boot, to seed the database. Preserve
# any config left by a v4 add-on install so the migration can import it. After
# that first boot the app ignores config.yaml entirely (settings live in the DB,
# edited via /admin).
import_legacy_config_once
if [ "${LEGACY_CONFIG_IMPORTED}" = "true" ]; then
  log "Imported legacy config.yaml for first-boot database migration"
fi

# Legacy s6 env injection: the v5 upstream image ships no s6-overlay, so these
# dirs do not exist and this loop is a no-op. Runtime env now reaches services
# via start.sh (which reads /data/runtime/app_secret and admin_password_hash and
# re-exports the option-derived vars). Kept as a harmless fallback.
for env_dir in "$S6_ENV_DIR_1" "$S6_ENV_DIR_2"; do
  if [ -d "$env_dir" ]; then
    printf '%s' "$IMPORT_MODE"            > "${env_dir}/IMPORT_MODE"
    printf '%s' "$APP_URL"               > "${env_dir}/APP_URL"
    printf '%s' "$APP_SECRET"            > "${env_dir}/APP_SECRET"
    printf '%s' "$TZ_VALUE"              > "${env_dir}/TZ"
    printf '%s' "$ADMIN_USERNAME"        > "${env_dir}/ADMIN_USERNAME"
    printf '%s' "$ADMIN_PASSWORD_HASH"   > "${env_dir}/ADMIN_PASSWORD_HASH"
    printf '%s' "$STRAVA_CLIENT_ID"      > "${env_dir}/STRAVA_CLIENT_ID"
    printf '%s' "$STRAVA_CLIENT_SECRET"  > "${env_dir}/STRAVA_CLIENT_SECRET"
    printf '%s' "$STRAVA_REFRESH_TOKEN"  > "${env_dir}/STRAVA_REFRESH_TOKEN"
    printf '%s' "$CADDY_LOG_LEVEL"       > "${env_dir}/CADDY_LOG_LEVEL"
  fi
done

# Export the vars the init-time console commands need, then run the fast config
# (migrate) phase. start.sh backgrounds the slow data phase after the web server
# is up, so boot does not block the HA watchdog.
export IMPORT_MODE APP_URL APP_SECRET ADMIN_USERNAME ADMIN_PASSWORD_HASH
[ -n "$STRAVA_CLIENT_ID" ]     && export STRAVA_CLIENT_ID
[ -n "$STRAVA_CLIENT_SECRET" ] && export STRAVA_CLIENT_SECRET
[ -n "$STRAVA_REFRESH_TOKEN" ] && export STRAVA_REFRESH_TOKEN
[ -n "$TZ_VALUE" ]             && export TZ="$TZ_VALUE"

# Run the fast config phase (migrate only); start.sh backgrounds the data phase.
if ! SFS_RECONCILE_PHASE=config sh /usr/local/bin/sfs-reconcile-config.sh; then
  fatal "Database migration failed during init"
  exit 1
fi

log "Persistent data root: /data"

log "Done"

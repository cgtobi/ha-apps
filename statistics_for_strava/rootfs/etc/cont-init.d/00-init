#!/usr/bin/with-contenv sh
set -eu

timestamp() {
  date +"%Y-%m-%dT%H:%M:%S%z"
}

log() {
  echo "$(timestamp) [init] $*"
}

warn() {
  echo "$(timestamp) [init] WARN: $*"
}

fatal() {
  echo "$(timestamp) [init] FATAL: $*"
}

log "Preparing persistent storage"

OPTIONS_FILE="/data/options.json"
HA_ADDON_CONFIG_DIR="/addon_configs/local_statistics_for_strava"
PERSIST_CONFIG_DIR="/data/config/app"
TARGET_CONFIG_DIR="/var/www/config/app"
TARGET_STORAGE_DIR="/var/www/storage"
# File-import watch dir. addon_config:rw mounts the add-on's config dir at /config
# inside the container (host: /addon_configs/local_statistics_for_strava), so files
# dropped here over SMB/CIFS are picked up by the upstream file-import pipeline.
WATCH_SOURCE_DIR="/config/watch"
TARGET_WATCH_DIR="/var/www/watch"
STARTUP_MARKER_FILE="/data/runtime/health.startup"
S6_ENV_DIR_1="/var/run/s6/container_environment"
S6_ENV_DIR_2="/run/s6/container_environment"

mkdir -p /data/build/html /data/build/api
mkdir -p /data/storage/database /data/storage/files/logs /data/storage/gear-maintenance
mkdir -p /data/runtime
mkdir -p "$PERSIST_CONFIG_DIR"

# Startup marker used by /healthz grace handling.
date +%s > "$STARTUP_MARKER_FILE"

# Ensure app config path points to persistent data.
if [ -L "$TARGET_CONFIG_DIR" ]; then
  rm -f "$TARGET_CONFIG_DIR"
elif [ -d "$TARGET_CONFIG_DIR" ]; then
  rm -rf "$TARGET_CONFIG_DIR"
elif [ -f "$TARGET_CONFIG_DIR" ]; then
  rm -f "$TARGET_CONFIG_DIR"
fi
mkdir -p /var/www/config
ln -s "$PERSIST_CONFIG_DIR" "$TARGET_CONFIG_DIR"

# Ensure app-relative storage path resolves to persistent /data/storage.
if [ -L "$TARGET_STORAGE_DIR" ]; then
  rm -f "$TARGET_STORAGE_DIR"
elif [ -d "$TARGET_STORAGE_DIR" ]; then
  rm -rf "$TARGET_STORAGE_DIR"
elif [ -f "$TARGET_STORAGE_DIR" ]; then
  rm -f "$TARGET_STORAGE_DIR"
fi
ln -s /data/storage "$TARGET_STORAGE_DIR"

# Backward-compatible import for existing user file locations.
import_legacy_config_once() {
  LEGACY_CONFIG_IMPORTED="false"
  if [ ! -f "$PERSIST_CONFIG_DIR/config.yaml" ]; then
    if [ -f "$HA_ADDON_CONFIG_DIR/config/app/config.yaml" ]; then
      cp "$HA_ADDON_CONFIG_DIR/config/app/config.yaml" "$PERSIST_CONFIG_DIR/config.yaml"
      LEGACY_CONFIG_IMPORTED="true"
    elif [ -f "$HA_ADDON_CONFIG_DIR/config.yaml" ]; then
      cp "$HA_ADDON_CONFIG_DIR/config.yaml" "$PERSIST_CONFIG_DIR/config.yaml"
      LEGACY_CONFIG_IMPORTED="true"
    fi
  fi
}

validate_yaml_file() {
  yaml_file="$1"
  php /usr/local/share/sfs/validate-app-config.php "$yaml_file" >/tmp/sfs-config-validate.log 2>&1
}

require_non_empty() {
  key="$1"
  value="$2"
  if [ -z "$value" ]; then
    fatal "Required option '${key}' is empty"
    exit 1
  fi
}

# Write runtime env expected by Symfony app.
if [ ! -f "$OPTIONS_FILE" ]; then
  fatal "Missing required ${OPTIONS_FILE}"
  exit 1
fi

read_opt() {
  key="$1"
  jq -r --arg k "$key" '.[$k] // ""' "$OPTIONS_FILE"
}

STRAVA_CLIENT_ID="$(read_opt strava_client_id)"
STRAVA_CLIENT_SECRET="$(read_opt strava_client_secret)"
STRAVA_REFRESH_TOKEN="$(read_opt strava_refresh_token)"
TZ_VALUE="$(read_opt tz)"
APP_CONFIG_YAML="$(read_opt app_config_yaml)"
IMPORT_MODE="$(read_opt import_mode)"
EXPOSE_SHARE="$(read_opt expose_share)"
: "${IMPORT_MODE:=stravaApi}"

# Strava credentials are only required in Strava-API import mode. In "files" mode
# the app imports activity files from the watch dir and needs no Strava tokens.
if [ "$IMPORT_MODE" = "stravaApi" ]; then
  require_non_empty "strava_client_id" "$STRAVA_CLIENT_ID"
  require_non_empty "strava_client_secret" "$STRAVA_CLIENT_SECRET"
  require_non_empty "strava_refresh_token" "$STRAVA_REFRESH_TOKEN"
fi
require_non_empty "tz" "$TZ_VALUE"

# Expose the file-import watch dir via the mapped add-on config dir so activity
# files can be provided over SMB/CIFS. Gated by expose_share: when off, the watch
# dir stays internal/unused. Same link idiom as the storage symlink above.
if [ "$EXPOSE_SHARE" = "true" ]; then
  if [ -L "$TARGET_WATCH_DIR" ]; then
    rm -f "$TARGET_WATCH_DIR"
  elif [ -d "$TARGET_WATCH_DIR" ]; then
    rm -rf "$TARGET_WATCH_DIR"
  elif [ -f "$TARGET_WATCH_DIR" ]; then
    rm -f "$TARGET_WATCH_DIR"
  fi
  if mkdir -p "$WATCH_SOURCE_DIR" 2>/dev/null; then
    ln -s "$WATCH_SOURCE_DIR" "$TARGET_WATCH_DIR"
    log "File-import watch dir exposed at ${WATCH_SOURCE_DIR} (host: /addon_configs/local_statistics_for_strava/watch)"
  else
    warn "expose_share=true but ${WATCH_SOURCE_DIR} is not writable; is 'addon_config:rw' mapped?"
  fi
fi

CONFIG_SOURCE="existing"
if [ -n "$APP_CONFIG_YAML" ]; then
  # Keep one authoritative reconciliation path used by init + services. Run only
  # the fast config phase here (render/validate/migrate); the slow data phase
  # (import + build-files) is launched in the background by start.sh after the
  # web server is up, so boot does not block the HA watchdog.
  if ! SFS_RECONCILE_PHASE=config sh /usr/local/bin/sfs-reconcile-config.sh; then
    fatal "Could not reconcile /data/config/app/config.yaml from /data/options.json"
    exit 1
  fi
  CONFIG_SOURCE="options"
else
  import_legacy_config_once
  if [ "${LEGACY_CONFIG_IMPORTED}" = "true" ]; then
    CONFIG_SOURCE="legacy"
  fi
fi

# Also inject env at s6 level so longrun services always receive these variables.
for env_dir in "$S6_ENV_DIR_1" "$S6_ENV_DIR_2"; do
  if [ -d "$env_dir" ]; then
    printf '%s' "$STRAVA_CLIENT_ID" > "${env_dir}/STRAVA_CLIENT_ID"
    printf '%s' "$STRAVA_CLIENT_SECRET" > "${env_dir}/STRAVA_CLIENT_SECRET"
    printf '%s' "$STRAVA_REFRESH_TOKEN" > "${env_dir}/STRAVA_REFRESH_TOKEN"
    printf '%s' "$TZ_VALUE" > "${env_dir}/TZ"
    printf '%s' "$IMPORT_MODE" > "${env_dir}/IMPORT_MODE"
    printf '%s' "$(read_opt caddy_log_level)" > "${env_dir}/CADDY_LOG_LEVEL"
  fi
done

if [ ! -f "$PERSIST_CONFIG_DIR/config.yaml" ]; then
  fatal "Missing required ${PERSIST_CONFIG_DIR}/config.yaml"
  fatal "Provide app_config_yaml in add-on options or place config at ${PERSIST_CONFIG_DIR}/config.yaml"
  exit 1
fi

if ! validate_yaml_file "$PERSIST_CONFIG_DIR/config.yaml"; then
  fatal "Invalid ${PERSIST_CONFIG_DIR}/config.yaml structure"
  sed -n '1,5p' /tmp/sfs-config-validate.log || true
  exit 1
fi

if grep -Eq '^[[:space:]]*appUrl:[[:space:]]*["'\'']?http://CHANGE_ME:8080/?["'\'']?[[:space:]]*$' "$PERSIST_CONFIG_DIR/config.yaml"; then
  warn "general.appUrl still uses placeholder http://CHANGE_ME:8080/"
  warn "This is accepted for Home Assistant ingress usage, but set a real public URL for direct access and webhook callbacks"
fi

rm -f /tmp/sfs-config-validate.log

log "Using config: ${PERSIST_CONFIG_DIR}/config.yaml"
log "Config source: ${CONFIG_SOURCE}"
log "Persistent data root: /data"

log "Done"

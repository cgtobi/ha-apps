{
	http_port 8080
	auto_https off

	frankenphp {
		num_threads 3
		worker {
			num 2
			file ./public/index.php
		}
	}

	log {
		output stdout
		format console
		level {$CADDY_LOG_LEVEL:ERROR}
	}
}

:8080 {
	root /var/www/public
	encode zstd br gzip

	# HA ingress support: the supervisor proxy strips the
	# /api/hassio_ingress/<token> prefix and forwards it as X-Ingress-Path.
	# Map it to X-Forwarded-Prefix so Symfony (which trusts the private-range
	# proxy, see config/packages/framework.yaml) generates redirects and
	# router/asset URLs under the ingress base path. Guarded so direct :8080
	# access (no ingress header) never receives a prefix.
	#
	# The app only ever sees an X-Forwarded-Prefix we set ourselves. When there is
	# no ingress request, strip any client-supplied value (prevents spoofing on an
	# exposed :8080); when HA's X-Ingress-Path is present, set the prefix from it
	# (this replaces any client-supplied value). The two are mutually exclusive by
	# matcher so their order never conflicts — a single unconditional strip plus a
	# conditional set would not work, because Caddy's headers handler applies
	# deletions after sets and would clobber our value on legit ingress requests.
	@noIngressPath not header X-Ingress-Path *
	request_header @noIngressPath -X-Forwarded-Prefix
	@hasIngressPath header X-Ingress-Path *
	request_header @hasIngressPath X-Forwarded-Prefix {header.X-Ingress-Path}

	# Lightweight health endpoint for HA watchdog checks.
	handle /healthz {
		rewrite * /healthz.php
		php
	}

	# Serve manifest from public root.
	handle /manifest.json {
		root * /var/www/public
		file_server
	}

	# Disable Topics tracking if not enabled explicitly: https://github.com/jkarlin/topics
	header {
		Cache-Control "no-cache, no-store, must-revalidate"
		?Permissions-Policy "browsing-topics=()"
	}

	# Serve dashboard index at / from generated static build output.
	@rootPath path /
	handle @rootPath {
		root * /data/build/html
		rewrite * /index.html
		file_server
	}

	# Compatibility fallback for malformed relative route ".html".
	@emptyHtmlPath path_regexp emptyhtml ^/\.html$
	handle @emptyHtmlPath {
		redir ./dashboard.html 302
	}

	# Serve static frontend build resources.
	handle /css/* {
		root * /var/www/public
		file_server
	}

	handle /js/* {
		root * /var/www/public
		file_server
	}

	handle /libraries/* {
		root * /var/www/public
		file_server
	}

	# Cache and serve static assets from Symfony public dir.
	handle /assets/* {
		header {
			Cache-Control "public, max-age=86400"
		}
		root * /var/www/public
		file_server
	}

	# Serve static .html from build/html
	@staticBuildFiles {
		path *.html
	}
	handle @staticBuildFiles {
		root * /data/build/html
		file_server
	}

	# Serve badge SVGs - no cache
	@badges path /files/*-badge.svg
	handle @badges {
		header {
			Cache-Control "no-cache, no-store, must-revalidate"
		}

		root * /data/storage
		file_server
	}

	# Serve other /files/* from storage
	handle /files/* {
		header {
			Cache-Control "public, max-age=31536000, immutable"
		}

		root * /data/storage
		file_server
	}

	# Serve /gear-maintenance/* from storage.
	handle /gear-maintenance/* {
		root * /data/storage
		file_server
	}

	# Serve everything else through Symfony.
	handle {
		@phpRoute {
			not file {path}
		}

		rewrite @phpRoute index.php

		@frontController path index.php
		php @frontController
	}

	# Handle error codes.
	handle_errors 403 404 {
		root /var/www/public
		rewrite * /{err.status_code}.html
		file_server
	}

	handle_errors 5xx {
		root /var/www/public
		rewrite * /50x.html
		file_server
	}

	handle_errors {
		respond "{err.status_code} {err.status_text}"
	}

	# Hide php and yaml file from filesystem
	file_server {
		hide *.php *.yaml *.yml
	}
}

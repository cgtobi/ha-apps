#!/usr/bin/env sh
set -eu

CONFIG_FILE="statistics_for_strava/config.yaml"
CHANGELOG_FILE="statistics_for_strava/CHANGELOG.md"
ADDON_DIR="statistics_for_strava"
CHECK_SCRIPT="scripts/check-release-consistency.sh"

if ! git rev-parse --git-dir >/dev/null 2>&1; then
  exit 0
fi

if [ ! -f "$CONFIG_FILE" ] || [ ! -f "$CHANGELOG_FILE" ]; then
  exit 0
fi

if [ ! -x "$CHECK_SCRIPT" ]; then
  echo "pre-commit: missing executable ${CHECK_SCRIPT}" >&2
  exit 1
fi

staged_any_in_addon="$(git diff --cached --name-only --diff-filter=ACMRD -- "${ADDON_DIR}/**" "${ADDON_DIR}/*" || true)"
if [ -z "$staged_any_in_addon" ]; then
  exit 0
fi

staged_config_changed="$(git diff --cached --name-only --diff-filter=ACMRD -- "$CONFIG_FILE" || true)"
staged_changelog_changed="$(git diff --cached --name-only --diff-filter=ACMRD -- "$CHANGELOG_FILE" || true)"

if [ -z "$staged_config_changed" ] || [ -z "$staged_changelog_changed" ]; then
  echo "pre-commit: Version change and changelog update are required" >&2
  exit 1
fi

"$CHECK_SCRIPT" --staged --require-bump
